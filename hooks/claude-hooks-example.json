{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["PATH_TO_REPO/hooks/hook_notify.py", "running"],
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["PATH_TO_REPO/hooks/hook_notify.py", "thinking"],
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["PATH_TO_REPO/hooks/hook_notify.py", "idle"],
            "timeout": 3
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["PATH_TO_REPO/hooks/hook_notify.py", "waiting"],
            "timeout": 3
          }
        ]
      }
    ]
  }
}
